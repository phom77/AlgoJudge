{
  "name": "algojudge-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "npm run monaco:prepare",
    "start": "ng serve",
    "prebuild": "npm run monaco:prepare",
    "build": "ng build",
    "prewatch": "npm run monaco:prepare",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:coverage": "ng test --watch=false --coverage",
    "api:generate": "ng-openapi-gen --config ng-openapi-gen.json",
    "api:check": "node scripts/check-api-client-drift.mjs",
    "monaco:prepare": "node scripts/prepare-monaco-css.mjs",
    "security:check": "node scripts/check-production-artifacts.mjs",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "npm run build && npm run security:check && playwright test",
    "test:e2e:ci": "playwright test",
    "check": "npm run api:check && npm run format:check && npm run lint && npm run test && npm run build && npm run security:check"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "marked": "18.0.6",
    "monaco-editor": "0.53.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.19",
    "@angular/cli": "21.2.19",
    "@angular/compiler-cli": "21.2.18",
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "angular-eslint": "21.4.0",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "jsdom": "28.1.0",
    "ng-openapi-gen": "1.0.5",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.10"
  }
}
