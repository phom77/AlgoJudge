{
  "Urls": "http://localhost:5018",
  "ConnectionStrings": { "DefaultConnection": "" },
  "ContentQueue": {
    "PollIntervalSeconds": 3,
    "LeaseDurationSeconds": 120,
    "HeartbeatIntervalSeconds": 30,
    "MaxAttempts": 3,
    "WorkerId": ""
  },
  "ContentGeneration": { "MaximumCaseCount": 500 },
  "DotNetGenerationSandbox": {
    "DockerImage": "algojudge/content-generator-dotnet:10.0.203-v1",
    "CompileTimeoutSeconds": 60,
    "RunTimeoutSeconds": 30,
    "DockerStartupAllowanceSeconds": 10,
    "MemoryMb": 512,
    "PidsLimit": 64,
    "OutputLimitBytes": 16777216
  },
  "Sandbox": {
    "DockerImage": "algojudge/judge-cpp17:14.3.0-v1",
    "CompileTimeoutSeconds": 30,
    "DockerStartupAllowanceSeconds": 10,
    "StdoutLimitBytes": 65536,
    "StderrLimitBytes": 65536,
    "PidsLimit": 32
  }
}
