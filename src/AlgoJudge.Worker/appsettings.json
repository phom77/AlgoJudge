{
  "Urls": "http://localhost:5017",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Sandbox": {
    "DockerImage": "algojudge/judge-cpp17:14.3.0-v1",
    "CompileTimeoutSeconds": 30,
    "DockerStartupAllowanceSeconds": 10,
    "StdoutLimitBytes": 65536,
    "StderrLimitBytes": 65536,
    "PidsLimit": 32
  },
  "Queue": {
    "PollIntervalSeconds": 3,
    "LeaseDurationSeconds": 60,
    "HeartbeatIntervalSeconds": 15,
    "MaxAttempts": 3,
    "WorkerId": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
